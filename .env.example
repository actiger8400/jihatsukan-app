# Vertex AI（GCP）認証情報（必須）
# サービスアカウントJSONキーファイルのパス（ローカル開発用）
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/vertex-key.json

# GCPプロジェクトID（JSONファイル内の "project_id" の値）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AIリージョン（Tokyo推奨）
GOOGLE_CLOUD_LOCATION=asia-northeast1

# Render等の本番環境用: JSON全体を1行で貼り付け（ローカルでは不要）
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# アプリケーションのログインパスワード（どちらか一方）
APP_PASSWORD=your_password_here
# or 推奨: bcryptハッシュを使用
# APP_PASSWORD_HASH=$2b$10$...

# セッション暗号化シークレット（本番環境では必須・ランダムな長い文字列）
SESSION_SECRET=change_to_random_long_string_in_production

# 環境（production / development）
NODE_ENV=development

# 許可するCORSオリジン（カンマ区切り、未設定なら同一オリジンのみ）
# ALLOWED_ORIGINS=https://example.com
